@startuml overview
!theme plain
skinparam backgroundColor #F4F6FB
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 13
skinparam ArrowColor #4A5568
skinparam ArrowThickness 2

skinparam rectangle {
  BorderThickness 2
  RoundCorner 14
}

skinparam component {
  BorderThickness 2
  RoundCorner 10
}

skinparam actor {
  BorderColor #2D3748
  BackgroundColor #EBF4FF
}

title <size:22><b>AaaS — Brain Tumor MRI Classification</b></size>\n<size:14><color:#718096>Cloud-Agnostic Analytics as a Service | AWS + Terraform</color></size>

' ─────────────────────────────────────────────────────
'  CLIENT LAYER
' ─────────────────────────────────────────────────────
rectangle "  <b>Client Layer</b>  " as CLIENT_LAYER #EBF8FF/D6EAF8 {
  actor "<b>User / Researcher</b>\n<size:10>MRI Image Upload</size>" as USER #DBEAFE
  component "<b>Flask Web App</b>\n<size:10>Bootstrap 5 UI\nUpload + Benchmark</size>" as WEBAPP #BFDBFE
}

' ─────────────────────────────────────────────────────
'  AWS CLOUD
' ─────────────────────────────────────────────────────
rectangle "  ☁  <b>AWS Cloud</b>  (us-east-1)  " as AWS #FFF8F0/FDEBD0 {

  ' API GATEWAY
  component "<color:#FF6B00><b>⚡ API Gateway</b></color>\n<size:10>REST API — /predict\nHTTPS · API Key Auth</size>" as APIGW #FFDDB3

  ' COMPUTE — two backends
  rectangle "  <b>Compute</b>  " as COMPUTE #FFF0F0/FFD5D5 {
    component "<color:#E53E3E><b>λ AWS Lambda</b></color>\n<size:10>PyTorch MobileNetV2\nContainer Image · 3008 MB</size>" as LAMBDA #FFB3B3
    component "<color:#C05621><b>⬡ ECS Fargate</b></color>\n<size:10>Flask Inference Service\nContainer · Auto-scaling</size>" as ECS #FDD9C0
  }

  ' CONTAINER REGISTRY
  component "<color:#D97706><b>📦 ECR</b></color>\n<size:10>Lambda Image\nECS Image</size>" as ECR #FDE68A

  ' STORAGE
  rectangle "  <b>Storage</b>  " as STORAGE #F0FFF4/C6F6D5 {
    component "<color:#276749><b>🗄  S3 — Models</b></color>\n<size:10>brain_tumor_model.pt\nbrain_tumor_model.onnx</size>" as S3_MODEL #9AE6B4
    component "<color:#276749><b>🗄  S3 — Images</b></color>\n<size:10>Uploaded MRI scans\nTemporary storage</size>" as S3_IMG #9AE6B4
    component "<color:#2B6CB0><b>⬡ DynamoDB</b></color>\n<size:10>Model Metadata\nname · path · version</size>" as DYNAMO #BEE3F8
  }

  ' SECURITY
  rectangle "  <b>Security</b>  " as SECURITY #FAF5FF/E9D8FD {
    component "<color:#6B46C1><b>🔑 IAM Roles</b></color>\n<size:10>Lambda · ECS · API GW\nLeast-privilege policies</size>" as IAM #D6BCFA
    component "<color:#553C9A><b>🔐 KMS</b></color>\n<size:10>Encryption at rest\nS3 · DynamoDB · Logs</size>" as KMS #D6BCFA
    component "<color:#44337A><b>🛡  Secrets Manager</b></color>\n<size:10>API Keys · Secrets\nRotation support</size>" as SECRETS #D6BCFA
  }
}

' ─────────────────────────────────────────────────────
'  IaC LAYER
' ─────────────────────────────────────────────────────
rectangle "  <b>Infrastructure as Code</b>  " as IAC #F0F9FF/CFFAFE {
  component "<color:#0891B2><b>⬛ Terraform</b></color>\n<size:10>8 Modular Configs\nAPI GW · Lambda · ECS\nS3 · DynamoDB · IAM\nECR · Security</size>" as TF #A5F3FC
}

' ─────────────────────────────────────────────────────
'  ARROWS — Request Flow
' ─────────────────────────────────────────────────────
USER       --> WEBAPP    : <size:11>Upload MRI\nJSON + Image</size>
WEBAPP     --> APIGW     : <size:11><b>POST /predict</b>\nmultipart/form-data</size>
APIGW      --> LAMBDA    : <size:11>Invoke\n(primary)</size> #E53E3E
APIGW      -[hidden]-> ECS
APIGW      --> ECS       : <size:11>Route\n(fallback)</size> #C05621

LAMBDA     --> S3_MODEL  : <size:11>Download\nmodel on\ncold start</size>
LAMBDA     --> DYNAMO    : <size:11>Lookup model\npath</size>
LAMBDA     --> S3_IMG    : <size:11>Store\nimage</size>

ECS        --> S3_MODEL  : <size:11>Load model</size>
ECS        --> DYNAMO    : <size:11>Lookup path</size>

ECR        ..> LAMBDA    : <size:10>pulls image</size> #888888
ECR        ..> ECS       : <size:10>pulls image</size> #888888

SECURITY   ..> COMPUTE   : <size:10>IAM·KMS\nprotect</size> #7C3AED
SECURITY   ..> STORAGE   : <size:10>encrypt\nat rest</size> #7C3AED

TF         ..> AWS       : <size:10>provisions\nall resources</size> #0891B2

LAMBDA     --> WEBAPP    : <size:11>{"classification": "glioma"\n "confidence": 0.98}</size>
WEBAPP     --> USER      : <size:11>Result +\nVisualization</size>

' ─────────────────────────────────────────────────────
'  LEGEND
' ─────────────────────────────────────────────────────
legend bottom right
  |= Symbol |= Meaning |
  | ──► | Primary data flow |
  | ····► | Infrastructure dependency |
  | <back:#FFB3B3>  </back> | Serverless compute |
  | <back:#9AE6B4>  </back> | Storage services |
  | <back:#D6BCFA>  </back> | Security layer |
  | <back:#A5F3FC>  </back> | Infrastructure as Code |
end legend

@enduml
